FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ============================================
# 시스템 패키지
# ============================================
RUN apt update && apt install -y \
    openssh-server sudo git curl wget unzip \
    build-essential ca-certificates \
    vim nano tmux htop jq \
    fzf ripgrep \
    postgresql-client \
    net-tools iputils-ping dnsutils \
    locales tzdata \
    python3 python3-pip python3-venv \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && ln -sf /usr/bin/pip3 /usr/bin/pip \
    && rm -rf /var/lib/apt/lists/*
RUN echo '[global]\nbreak-system-packages = true' > /etc/pip.conf

# ============================================
# 한글 로케일 + 서울 타임존
# ============================================
RUN locale-gen ko_KR.UTF-8 \
    && ln -sf /usr/share/zoneinfo/Asia/Seoul /etc/localtime
ENV LANG=ko_KR.UTF-8
ENV LC_ALL=ko_KR.UTF-8

# ============================================
# nvm + Node.js 22 LTS
# ============================================
ENV NVM_DIR=/usr/local/nvm
RUN mkdir -p $NVM_DIR \
    && curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash \
    && . $NVM_DIR/nvm.sh \
    && nvm install 22 \
    && nvm alias default 22 \
    && ln -sf $(ls -d $NVM_DIR/versions/node/v22.* | tail -1) $NVM_DIR/versions/node/v22 \
    && npm install -g npm@latest pnpm yarn typescript
ENV PATH=$NVM_DIR/versions/node/v22/bin:$PATH

# ============================================
# Playwright 의존성 + Chromium + 한글폰트
# ============================================
RUN apt update && apt install -y \
    libnss3 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libxkbcommon0 libxcomposite1 \
    libxdamage1 libxrandr2 libgbm1 libasound2t64 \
    libpango-1.0-0 libcairo2 \
    chromium-browser fonts-nanum fonts-noto-cjk \
    && rm -rf /var/lib/apt/lists/*

# ============================================
# Supabase CLI (직접 설치)
# ============================================
RUN curl -fsSL https://github.com/supabase/cli/releases/latest/download/supabase_linux_amd64.tar.gz | tar -xz -C /usr/local/bin

# ============================================
# Python 패키지
# ============================================
RUN pip install --no-cache-dir \
    openai anthropic \
    langchain-core langchain-openai langchain-anthropic \
    langchain-google-genai langchain-ollama \
    chromadb kiwipiepy \
    fastapi uvicorn pydantic-settings \
    sse-starlette sqlmodel jinja2 python-multipart \
    playwright beautifulsoup4 lxml \
    requests httpx aiohttp \
    PyPDF2 python-docx openpyxl markdown nh3 PyYAML \
    pandas \
    supabase python-dotenv \
    fastmcp notion-client \
    pytest black ruff \
    pydantic

# Playwright 브라우저 설치
RUN playwright install chromium

# ============================================
# GitHub CLI
# ============================================
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt update && apt install -y gh \
    && rm -rf /var/lib/apt/lists/*

# ============================================
# 사용자 생성 + 설정
# ============================================
ARG USERNAME=user
ARG PASSWORD=changeme
RUN useradd -m -s /bin/bash ${USERNAME} \
    && echo "${USERNAME}:${PASSWORD}" | chpasswd \
    && usermod -aG sudo ${USERNAME} \
    && su - ${USERNAME} -c "git config --global --add safe.directory /workspace" \
    && echo "set -g mouse on" > /home/${USERNAME}/.tmux.conf \
    && chown ${USERNAME}:${USERNAME} /home/${USERNAME}/.tmux.conf \
    && echo 'export NVM_DIR=/usr/local/nvm' >> /home/${USERNAME}/.bashrc \
    && echo '[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"' >> /home/${USERNAME}/.bashrc \
    && echo 'export PATH="$HOME/.local/bin:$PATH"' >> /home/${USERNAME}/.bashrc \
    && chown -R ${USERNAME}:${USERNAME} /usr/local/nvm

# ============================================
# Claude Code + OpenAI Codex
# ============================================
RUN su - ${USERNAME} -c "curl -fsSL https://claude.ai/install.sh | bash"
RUN . /usr/local/nvm/nvm.sh && npm install -g @openai/codex

# 홈 디렉토리 초기 파일 백업 (bind mount 시 복원용)
RUN cp -a /home/${USERNAME} /etc/docker-home-init

# ============================================
# SSH 설정
# ============================================
RUN mkdir -p /run/sshd \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin no/' /etc/ssh/sshd_config \
    && sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config

# ============================================
# 작업 디렉토리
# ============================================
WORKDIR /workspace
RUN chown -R ${USERNAME}:${USERNAME} /workspace

COPY entrypoint.sh /usr/local/bin/entrypoint.sh

EXPOSE 22 5011-5019

ENTRYPOINT ["entrypoint.sh"]
CMD ["/usr/sbin/sshd", "-D"]
