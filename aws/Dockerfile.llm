ARG BASE_IMAGE=vllm/vllm-openai:v0.18.0
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive
ENV USERNAME=user
ENV PASSWORD=changeme
ENV CONTAINER_UID=1000
ENV CONTAINER_GID=1000

# ============================================
# 시스템 패키지
# ============================================
RUN apt-get update && apt-get install -y \
    openssh-server sudo git curl wget \
    build-essential ca-certificates \
    vim nano tmux htop jq \
    fzf ripgrep \
    bubblewrap \
    net-tools iputils-ping dnsutils \
    locales tzdata \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

# ============================================
# 한글 로케일 + 서울 타임존
# ============================================
RUN locale-gen ko_KR.UTF-8 \
    && ln -sf /usr/share/zoneinfo/Asia/Seoul /etc/localtime
ENV LANG=ko_KR.UTF-8
ENV LC_ALL=ko_KR.UTF-8

# ============================================
# nvm + Node.js 22 LTS (sudo 없이 npm 사용)
# ============================================
ENV NVM_DIR=/usr/local/nvm
RUN mkdir -p $NVM_DIR \
    && curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash \
    && . $NVM_DIR/nvm.sh \
    && nvm install 22 \
    && nvm alias default 22 \
    && ln -sf $(ls -d $NVM_DIR/versions/node/v22.* | tail -1) $NVM_DIR/versions/node/v22 \
    && npm install -g @openai/codex
ENV PATH=$NVM_DIR/versions/node/v22/bin:$PATH

# ============================================
# 사용자 생성은 런타임(entrypoint)에서 처리
# Claude Code도 런타임에 사용자별 설치 (홈 bind mount 시 persist)
# ============================================

# ============================================
# SSH 설정
# ============================================
RUN mkdir -p /run/sshd \
    && printf "Port 5555\nPermitRootLogin no\nPasswordAuthentication yes\n" > /etc/ssh/sshd_config.d/custom.conf

# ============================================
# 작업 디렉토리
# ============================================
WORKDIR /workspace

COPY entrypoint-llm.sh /usr/local/bin/entrypoint-llm.sh
RUN chmod +x /usr/local/bin/entrypoint-llm.sh

EXPOSE 5555

ENTRYPOINT ["/usr/local/bin/entrypoint-llm.sh"]
CMD ["/usr/sbin/sshd", "-D"]
