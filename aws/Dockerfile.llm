ARG BASE_IMAGE
FROM ${BASE_IMAGE}

# 환경 모드: dev (개발) | prd (운영)
# - dev: nvm + Node + codex 빌드 (Claude Code/codex 사용)
# - prd: 위 항목 스킵 → 이미지 슬림화
ARG MODE=dev

ENV DEBIAN_FRONTEND=noninteractive

# ============================================
# 시스템 패키지
# ============================================
RUN apt-get update && apt-get install -y \
    openssh-server sudo git curl wget \
    build-essential ca-certificates \
    vim nano tmux htop jq \
    fzf ripgrep \
    bubblewrap \
    net-tools iputils-ping dnsutils \
    locales tzdata \
    # Playwright/Puppeteer headless Chrome 의존성
    libnspr4 libnss3 \
    libatk1.0-0 libatk-bridge2.0-0 libatspi2.0-0 \
    libxcomposite1 libxdamage1 \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

# ============================================
# 한글 로케일 + 서울 타임존
# ============================================
RUN locale-gen ko_KR.UTF-8 \
    && ln -sf /usr/share/zoneinfo/Asia/Seoul /etc/localtime \
    && echo "Asia/Seoul" > /etc/timezone
ENV LANG=ko_KR.UTF-8
ENV LC_ALL=ko_KR.UTF-8

# ============================================
# nvm + Node.js LTS + codex (dev 전용)
# - prd: 빌드 스킵 → 이미지 슬림화 (Claude Code/codex 미사용)
# ============================================
ENV NVM_DIR=/usr/local/nvm
RUN if [ "$MODE" = "dev" ]; then \
        mkdir -p $NVM_DIR \
        && curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash \
        && . $NVM_DIR/nvm.sh \
        && nvm install --lts \
        && nvm alias default lts/* \
        && ln -sf $(ls -td $NVM_DIR/versions/node/v* | head -1) $NVM_DIR/versions/node/default \
        && npm install -g @openai/codex; \
    fi
# PATH는 dev/prd 공통 (prd 이미지엔 이 디렉토리가 없지만 셸이 비존재 경로를 무시하므로 무해)
ENV PATH=$NVM_DIR/versions/node/default/bin:$PATH

# ============================================
# 사용자 생성은 런타임(entrypoint)에서 처리
# Claude Code도 런타임에 사용자별 설치 (홈 bind mount 시 persist)
# ============================================

# ============================================
# SSH 설정
# ============================================
RUN mkdir -p /run/sshd \
    && printf "Port 5555\nPermitRootLogin no\nPasswordAuthentication yes\n" > /etc/ssh/sshd_config.d/custom.conf

# ============================================
# Python 패키지 (빌드 타임)
# ============================================
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt \
    && pip install --no-cache-dir --no-deps "transformers>=5.5.0"

# ============================================
# code-server (브라우저 기반 VS Code) — 폐쇄망 컨테이너 IDE
# ============================================
ARG CODE_SERVER_VERSION=4.116.0
RUN curl -fsSL "https://github.com/coder/code-server/releases/download/v${CODE_SERVER_VERSION}/code-server-${CODE_SERVER_VERSION}-linux-amd64.tar.gz" \
      | tar -xz -C /opt/ \
    && ln -s /opt/code-server-${CODE_SERVER_VERSION}-linux-amd64/bin/code-server /usr/local/bin/code-server \
    && mkdir -p /opt/code-server-extensions

# ============================================
# VS Code 확장 사이드로드 (폐쇄망 대응)
# - vsix/ 폴더의 *.vsix 를 빌드 타임에 자동 설치
# - /opt/code-server-extensions 에 설치 → 홈 bind mount 영향 없음
# - 폴더가 비어 있어도 빌드 성공 (find 특성)
# ============================================
COPY vsix/ /tmp/vsix/
RUN find /tmp/vsix -name "*.vsix" -type f -exec \
        code-server --extensions-dir /opt/code-server-extensions --install-extension {} \; \
    && chmod -R a+rX /opt/code-server-extensions \
    && rm -rf /tmp/vsix

# ============================================
# 작업 디렉토리
# ============================================
WORKDIR /workspace

COPY entrypoint-llm.sh /usr/local/bin/entrypoint-llm.sh
RUN chmod +x /usr/local/bin/entrypoint-llm.sh

EXPOSE 5555

ENTRYPOINT ["/usr/local/bin/entrypoint-llm.sh"]
CMD ["/usr/sbin/sshd", "-D"]
