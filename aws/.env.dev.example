# ============================================
# 사용자 설정 (setup-ec2.sh + docker-compose 공용)
# ============================================

# 환경 모드: dev | prd
# - dev: nvm + Node + codex 빌드, Claude Code 자동 설치, 개발 도구 풀세트
# - prd: 위 항목 스킵 → 이미지 슬림화 (운영 EC2)
MODE=dev

USERNAME=user
PASSWORD=changeme
CONTAINER_UID=2000
CONTAINER_GID=2000

# ============================================
# EC2 호스트 설정 (setup-ec2.sh에서 사용)
# ============================================

# EBS 볼륨 디바이스 (lsblk로 확인, 예: /dev/nvme0n1p1)
VOLUME_DEVICE=
# EC2 호스트 SSH 포트 (기본 22 대신 변경)
SSH_PORT=5555
# Docker GPU 테스트 이미지
CUDA_TEST_IMAGE=nvidia/cuda:12.8.1-base-ubuntu24.04
# vLLM 베이스 이미지 (버전 업그레이드 시 여기만 변경)
VLLM_IMAGE=vllm/vllm-openai:v0.19.1
# 빌드된 이미지 이름 (dev/prd 분리)
LLM_IMAGE_NAME=llm-dev

# ============================================
# 경로 설정
# ============================================

# EBS 마운트 경로 (setup-ec2.sh + docker-compose 공용)
VOLUME_PATH=/volume
# HuggingFace 토큰 (게이트 모델용 — 서버 구성 시 입력)
HF_TOKEN=
# 추가 pip requirements 파일 경로 (컨테이너 내부 기준 — dev는 보통 비워둠)
EXTRA_REQUIREMENTS=/data/requirements.txt

# ============================================
# 포트 설정 (서버 구성 시 충돌 회피용으로 직접 수정 가능, 기본 5000~5xxx)
# ============================================

# 메인 사용자 SSH 포트 (호스트 → 컨테이너 5555)
LLM_SSH_PORT=5000
# 서비스용 포트 (Jupyter, Tensorboard, vLLM API 등) — 단일(5031) 또는 range(5001-5009)
LLM_EXTRA_PORTS=5031
# code-server 전용 포트 (LLM_EXTRA_PORTS 와 겹치지 않게 지정)
LLM_CODE_SERVER_PORT=5500

# ============================================
# 리소스 설정 (서버 사양에 맞춰 조정 — 예시는 g6e.12xlarge 384GiB RAM)
# ============================================

# 컨테이너 메모리 (호스트 여유 확보)
LLM_MEMORY=48g
# 공유 메모리 (멀티GPU 통신용)
SHM_SIZE=16g
# GPU 할당 (all = 전체, 0,1 = 특정 GPU 번호)
LLM_GPUS=all

# ============================================
# 다중 사용자: ./user.sh 로 관리
#   ./user.sh up alice --gpus 0,1
#   ./user.sh up bob --password secret --gpus 2,3
#   ./user.sh list
#   ./user.sh down alice
# 포트: docker-compose 메인 5000-5009, user.sh 5010-5499 (사용자당 10포트)
# ============================================
