# ============================================
# EC2 서버 세팅 (setup-ec2.sh에서 사용)
# ============================================
SETUP_USERNAME=user              # EC2 호스트 사용자명
SETUP_PASSWORD=changeme          # EC2 호스트 비밀번호
WORKSPACE_DEVICE=                # /workspace용 EBS 디바이스 (예: /dev/nvme1n1, lsblk로 확인)
DATA_DEVICE=                     # /data용 EBS 디바이스 (예: /dev/nvme2n1, lsblk로 확인)

# ============================================
# 컨테이너 사용자 설정 (docker-compose에서 사용)
# ============================================
USERNAME=user
PASSWORD=changeme
UID=1000
GID=1000

# ============================================
# vLLM 서빙 설정
# ============================================
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_TP_SIZE=1                # Tensor Parallel GPU 수 (1=단일GPU, 2+=멀티GPU)
VLLM_GPU_MEM_UTIL=0.9         # GPU 메모리 사용률 (0.0~1.0)
VLLM_MAX_MODEL_LEN=4096       # 최대 시퀀스 길이
HF_TOKEN=                     # HuggingFace 토큰 (게이트 모델용)

# ============================================
# 경로 설정
# ============================================
MODEL_PATH=/data/models        # 호스트의 모델 저장 경로
DATA_PATH=/data                # 호스트의 데이터 경로
EXTRA_REQUIREMENTS=            # 추가 pip requirements 파일 경로 (컨테이너 내부 기준)

# ============================================
# 포트 설정
# ============================================
LLM_API_PORT=8000              # vLLM API 포트
LLM_DEV_SSH_PORT=5020          # 개발환경 SSH 포트

# ============================================
# 리소스 설정
# ============================================
LLM_MEMORY=512g                # 컨테이너 메모리 제한
SHM_SIZE=8g                    # 공유 메모리 크기
LLM_SERVE_GPU_COUNT=all        # 서빙 GPU 수 (all 또는 숫자)
LLM_DEV_GPU_COUNT=all          # 개발 GPU 수

# ============================================
# 다중 사용자 (docker-compose.yml에서 주석 해제 후 사용)
# ============================================
# ALICE_PASSWORD=changeme
# BOB_PASSWORD=changeme
