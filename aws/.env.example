# ============================================
# EC2 서버 세팅 (setup-ec2.sh에서 사용)
# ============================================
SETUP_USERNAME=user              # EC2 호스트 사용자명
SETUP_PASSWORD=changeme          # EC2 호스트 비밀번호
VOLUME_DEVICE=                   # EBS 볼륨 디바이스 (lsblk로 확인, 예: /dev/nvme1n1)
SSH_PORT=5555                    # EC2 호스트 SSH 포트 (기본 22 대신 변경)

# ============================================
# 컨테이너 사용자 설정 (docker-compose에서 사용)
# ⚠️ USERNAME은 SETUP_USERNAME과 동일해야 볼륨 경로가 일치합니다
# ============================================
USERNAME=user
PASSWORD=changeme
CONTAINER_UID=1000
CONTAINER_GID=1000

# ============================================
# 경로 설정
# ============================================
VOLUME_PATH=/volume               # EBS 마운트 경로 (setup-ec2.sh + docker-compose 공용)
HF_TOKEN=                         # HuggingFace 토큰 (게이트 모델용)
EXTRA_REQUIREMENTS=               # 추가 pip requirements 파일 경로 (컨테이너 내부 기준)

# ============================================
# 포트 설정
# ============================================
LLM_SSH_PORT=5020                 # SSH 포트
LLM_API_PORT=8000                 # vLLM API 포트 (컨테이너 내에서 서빙 시)

# ============================================
# 리소스 설정 (g6e.12xlarge: 384GiB RAM, L40S x4)
# ============================================
LLM_MEMORY=360g                   # 컨테이너 메모리 (384GiB 중 호스트 여유 확보)
SHM_SIZE=16g                      # 공유 메모리 (멀티GPU 통신용)
LLM_GPU_COUNT=all                 # GPU 수 (all = L40S 4개)

# ============================================
# 다중 사용자 (docker-compose.yml에서 주석 해제 후 사용)
# ============================================
# ALICE_PASSWORD=changeme
# BOB_PASSWORD=changeme
