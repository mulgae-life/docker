# ============================================
# EC2 서버 세팅 (setup-ec2.sh에서 사용)
# ============================================

# EC2 호스트 사용자명
SETUP_USERNAME=user
# EC2 호스트 비밀번호
SETUP_PASSWORD=changeme
# EBS 볼륨 디바이스 (lsblk로 확인, 예: /dev/nvme1n1)
VOLUME_DEVICE=
# EC2 호스트 SSH 포트 (기본 22 대신 변경)
SSH_PORT=5555
# Docker GPU 테스트 이미지
CUDA_TEST_IMAGE=nvidia/cuda:12.8.1-base-ubuntu24.04

# ============================================
# 컨테이너 사용자 설정 (docker-compose에서 사용)
# ⚠️ USERNAME은 SETUP_USERNAME과 동일해야 볼륨 경로가 일치합니다
# ============================================
USERNAME=user
PASSWORD=changeme
CONTAINER_UID=1000
CONTAINER_GID=1000
# vLLM 베이스 이미지 (버전 업그레이드 시 여기만 변경)
VLLM_IMAGE=vllm/vllm-openai:v0.18.0
# 빌드된 이미지 이름
LLM_IMAGE_NAME=llm-dev

# ============================================
# 경로 설정
# ============================================

# EBS 마운트 경로 (setup-ec2.sh + docker-compose 공용)
VOLUME_PATH=/volume
# HuggingFace 토큰 (게이트 모델용)
HF_TOKEN=
# 추가 pip requirements 파일 경로 (컨테이너 내부 기준)
EXTRA_REQUIREMENTS=

# ============================================
# 포트 설정
# ============================================

# SSH 포트
LLM_SSH_PORT=5020
# vLLM API 포트 (컨테이너 내에서 서빙 시)
LLM_API_PORT=8000
# 추가 포트 범위 (Jupyter, Tensorboard 등 사용자 서비스용)
LLM_EXTRA_PORTS=5021-5029

# ============================================
# 리소스 설정 (g6e.12xlarge: 384GiB RAM, L40S x4)
# ============================================

# 컨테이너 메모리 (384GiB 중 호스트 여유 확보)
LLM_MEMORY=360g
# 공유 메모리 (멀티GPU 통신용)
SHM_SIZE=16g
# GPU 수 (all = L40S 4개)
LLM_GPU_COUNT=all

# ============================================
# 다중 사용자 (docker-compose.yml에서 주석 해제 후 사용)
# ============================================
# ALICE_USERNAME=alice
# ALICE_PASSWORD=changeme
# ALICE_SSH_PORT=5030
# ALICE_API_PORT=5031
# ALICE_EXTRA_PORTS=5032-5039
# BOB_USERNAME=bob
# BOB_PASSWORD=changeme
# BOB_SSH_PORT=5040
# BOB_API_PORT=5041
# BOB_EXTRA_PORTS=5042-5049
